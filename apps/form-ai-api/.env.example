# 复制为 apps/form-ai-api/.env 后按需填写（勿提交含真实 Key 的 .env）

NODE_ENV=development

# 监听端口（优先于通用 PORT）
FORM_AI_API_PORT=3088

# DeepSeek（必填才能调 /form-ai/generate）
DEEPSEEK_API_KEY=
# MODEL_NAME=deepseek-chat
# BASE_URL=https://api.deepseek.com

# ---------- CORS ----------
# 生产环境（NODE_ENV=production）必须配置：浏览器来源白名单，逗号分隔、完整 Origin，无路径、无尾斜杠。
# 示例：FORM_AI_CORS_ORIGINS=https://designer.example.com,https://www.example.com
# FORM_AI_CORS_ORIGINS=

# 仅排障：对任意 Origin 放行（勿长期用于生产）
# FORM_AI_CORS_ALLOW_ALL=0

# 是否允许携带 Cookie / Authorization 跨域（默认 true；与 credentials: true 一致）
# FORM_AI_CORS_CREDENTIALS=true
