{
  "name": "@cjx-low-code/antdv",
  "version": "1.0.0",
  "license": "MIT",
  "main": "lib",
  "module": "esm",
  "umd:main": "dist/cjx-low-code.antdv.umd.production.js",
  "unpkg": "dist/cjx-low-code.antdv.umd.production.js",
  "jsdelivr": "dist/cjx-low-code.antdv.umd.production.js",
  "jsnext:main": "esm",
  "types": "lib/index.d.ts",
  "sideEffects": [
    "dist/*",
    "esm/*.js",
    "lib/*.js",
    "src/*.ts",
    "*.scss"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "vuepress dev docs",
    "build": "rimraf -rf lib esm dist && npm run create:style && npm run build:cjs && npm run build:esm && npm run build:umd && npm run build:style",
    "create:style": "ts-node create-style",
    "build:style": "ts-node build-style",
    "build:cjs": "ttsc  --declaration",
    "build:esm": "ttsc --declaration --module es2015 --outDir esm",
    "build:umd": "rollup --config",
    "build:docs": "vuepress build docs"
  },
  "peerDependencies": {
    "ant-design-vue": "^4.2.6",
    "vue": "^3.5.4"
  },
  "dependencies": {
    "@cjx-low-code/core": "workspace:*",
    "@cjx-low-code/json-schema": "workspace:*",
    "@cjx-low-code/reactivity": "workspace:*",
    "@cjx-low-code/reactivity-vue": "workspace:*",
    "@cjx-low-code/shared": "workspace:*",
    "@cjx-low-code/vue": "workspace:*"
  },
  "devDependencies": {
    "ant-design-vue": "^4.2.6",
    "codesandbox": "^2.2.3",
    "core-js": "^2.4.0",
    "ts-import-plugin": "^2.0.0",
    "ttypescript": "^1.5.15",
    "vue": "^3.5.4",
    "vuepress": "^1.8.2",
    "vuepress-plugin-typescript": "^0.3.1"
  },
  "engines": {
    "npm": ">=3.0.0"
  }
}
