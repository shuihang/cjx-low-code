{
  "name": "@cjx-low-code/reactivity-vue",
  "version": "1.0.1",
  "license": "MIT",
  "main": "lib",
  "module": "esm",
  "umd:main": "dist/cjx-low-code.reactivity-vue.umd.production.js",
  "unpkg": "dist/cjx-low-code.reactivity-vue.umd.production.js",
  "jsdelivr": "dist/cjx-low-code.reactivity-vue.umd.production.js",
  "jsnext:main": "esm",
  "types": "esm/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rimraf -rf lib esm dist && npm run build:cjs && npm run build:esm && npm run build:umd",
    "build:cjs": "tsc --project tsconfig.build.json",
    "build:esm": "tsc --project tsconfig.build.json --module es2015 --outDir esm",
    "build:umd": "rollup --config"
  },
  "peerDependencies": {
    "vue": "^3.5.4"
  },
  "dependencies": {
    "@cjx-low-code/reactivity": "workspace:*",
    "@cjx-low-code/shared": "workspace:*"
  },
  "devDependencies": {
    "core-js": "^2.4.0",
    "vue": "^3.5.4"
  },
  "engines": {
    "npm": ">=3.0.0"
  }
}
