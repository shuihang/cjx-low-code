{
  "name": "@cjx-low-code/element-plus",
  "version": "2.0.0",
  "license": "MIT",
  "main": "lib",
  "module": "esm",
  "umd:main": "dist/cjx-low-code.element-plus.umd.production.js",
  "unpkg": "dist/cjx-low-code.element-plus.umd.production.js",
  "jsdelivr": "dist/cjx-low-code.element-plus.umd.production.js",
  "jsnext:main": "esm",
  "types": "esm/index.d.ts",
  "sideEffects": [
    "dist/*",
    "esm/*.js",
    "lib/*.js",
    "src/*.ts",
    "*.scss"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "vitepress dev docs",
    "build": "rimraf -rf lib esm dist && npm run create:style && npm run build:cjs && npm run build:esm && npm run build:umd && npm run build:style",
    "create:style": "ts-node create-style",
    "build:style": "ts-node build-style",
    "build:cjs": "tsc --project tsconfig.build.json --declaration",
    "build:esm": "tsc --project tsconfig.build.json --declaration --module es2015 --outDir esm",
    "build:umd": "rollup --config",
    "build:docs": "vitepress build docs"
  },
  "peerDependencies": {
    "element-plus": "^2.13.2",
    "vue": "^3.5.4"
  },
  "dependencies": {
    "@cjx-low-code/core": "workspace:*",
    "@cjx-low-code/json-schema": "workspace:*",
    "@cjx-low-code/reactivity": "workspace:*",
    "@cjx-low-code/reactivity-vue": "workspace:*",
    "@cjx-low-code/shared": "workspace:*",
    "@cjx-low-code/vue": "workspace:*"
  },
  "devDependencies": {
    "codesandbox": "^2.2.3",
    "core-js": "^2.4.0",
    "element-plus": "^2.13.5",
    "ts-import-plugin": "^2.0.0",
    "ts-node": "^10.9.2",
    "ttypescript": "^1.5.15",
    "vitepress": "1.6.4",
    "vue": "^3.5.4",
    "vuepress-plugin-typescript": "^0.3.1"
  },
  "engines": {
    "npm": ">=3.0.0"
  }
}
