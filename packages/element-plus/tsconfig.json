{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./lib",
    "skipLibCheck": true,
    "jsx": "preserve",
    "paths": {
      "@formily/*": ["../../packages/*"]
    },
    "plugins": [{ "transform": "./transformer.ts", "after": true }],
    "lib": ["ESNext", "DOM"]
  },
  "include": ["./src/**/*.ts", "./src/**/*.tsx"],
  "exclude": ["./esm/*", "./lib/*"]
}
